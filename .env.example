# Токен сообщества VK
# Получить: сообщество → Управление → Работа с API → Создать ключ
# Необходимые права: доступ к сообщениям сообщества

VK_TOKEN=your_vk_community_token_here

# VK ID получателей через запятую

VK_RECIPIENTS=123456789,987654321

# Секретный ключ для защиты webhook
# Придумай любую строку, укажи её же в настройках Tilda

WEBHOOK_SECRET=your_secret_key_here
